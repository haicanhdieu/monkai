# Vercel Blob store read-write token (from store settings)
BLOB_READ_WRITE_TOKEN=

# Optional: override book-data source directory (default: apps/crawler/data/book-data)
# BOOK_DATA_SRC=

# Blob store root URL (no trailing slash). Set after first upload; required for deploy:reader
VITE_BOOK_DATA_URL=

# Optional: Vercel auth for CI / non-interactive deploy
# VERCEL_TOKEN=
