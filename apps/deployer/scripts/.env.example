# Copy this file to .env in this directory (scripts/.env) and fill in values.
# Do not commit .env — it contains secrets.

# --- Vercel Blob (upload-book-data-to-blob.mjs) ---
# From Vercel Dashboard → Storage → Blob → your store → Read-write token
# BLOB_READ_WRITE_TOKEN=

# --- Cloudflare R2 (upload-book-data-to-r2.mjs) ---
# From Cloudflare Dashboard → R2 → Manage R2 API Tokens
# CLOUDFLARE_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# --- Reader deploy (deploy-reader-static.mjs) ---
# Root URL for book-data (no trailing slash). Use Blob store root or R2 public URL.
# After first upload, set to the URL the upload script prints (e.g. https://xxx.public.blob.vercel-storage.com or https://pub-xxxx.r2.dev).
# VITE_BOOK_DATA_URL=

# --- Optional ---
# Source directory for book-data. Default: apps/crawler/data/book-data
# BOOK_DATA_SRC=

# Vercel CLI auth for non-interactive deploy (e.g. CI)
# VERCEL_TOKEN=

# Base path if reader is served under a path (default /)
# VITE_BASE_PATH=
