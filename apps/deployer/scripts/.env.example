# Copy this file to .env in this directory (scripts/.env) and fill in values.
# Do not commit .env — it contains secrets.

# --- Vercel Blob (upload-book-data-to-blob.mjs) ---
# From Vercel Dashboard → Storage → Blob → your store → Read-write token
# BLOB_READ_WRITE_TOKEN=

# --- Cloudflare R2 (upload-book-data-to-r2.mjs) ---
# From Cloudflare Dashboard → R2 → Manage R2 API Tokens
# CLOUDFLARE_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# --- Reader deploy (deploy-reader-static.mjs) ---
# Root URL for book-data (no trailing slash).
# Windows server via Cloudflare quick-tunnel: https://<random>.trycloudflare.com
#   Get the URL after each server restart: docker compose logs cloudflared 2>&1 | grep trycloudflare
# Pi server (primary): https://ntm-pub.ddns.net
# R2 (backup): set to the URL printed by upload-book-data-to-r2.mjs after first upload (e.g. https://pub-xxxx.r2.dev)
# VITE_BOOK_DATA_URL=

# --- OneDrive (upload-book-data-to-onedrive.mjs) ---
# rclone remote name — configure once with: rclone config
# ONEDRIVE_REMOTE=onedrive-monkai
# Source directory on Windows server (used by OneDrive sync script)
# BOOK_DATA_SRC=D:\ntm\monkai\apps\crawler\data\book-data

# --- Optional ---
# Vercel CLI auth for non-interactive deploy (e.g. CI)
# VERCEL_TOKEN=

# Base path if reader is served under a path (default /)
# VITE_BASE_PATH=
