# Absolute path to the book-data directory on the host.
#
# Docker Engine in WSL2 (recommended — see migrate-docker-desktop-to-engine.md):
#   Use the WSL2-format path: /mnt/<drive>/...
#   e.g. /mnt/c/Users/you/monkai/apps/crawler/data/book-data
#
# Docker Desktop on Windows (legacy):
#   Use forward slashes — Docker Desktop normalises them.
#   e.g. C:/Users/you/monkai/apps/crawler/data/book-data
BOOK_DATA_PATH=/mnt/c/Users/you/monkai/apps/crawler/data/book-data

# url-watcher: auto-updates vercel.json + ci.yml when cloudflared tunnel URL changes
#
# WSL2-format path to the repo root on the host.
#   e.g. /mnt/d/ntm/monkai
REPO_PATH=/mnt/c/Users/you/monkai

# Base64-encoded GitHub deploy private key (avoids Docker file-sharing issues).
# Generate: base64 -w0 ~/.ssh/id_rsa_github_kms   (Linux/WSL2)
#           [Convert]::ToBase64String([IO.File]::ReadAllBytes('C:\...\id_rsa_github_kms'))  (PowerShell)
SSH_PRIVATE_KEY=<base64-encoded-private-key>

GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your@email.com
