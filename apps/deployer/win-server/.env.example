# ngrok auth token — copy from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_token_here

# ngrok static domain — e.g. monkai-book-data.ngrok-free.app
NGROK_DOMAIN=your-domain.ngrok-free.app

# Absolute path to the book-data directory on the host
# Windows: use forward slashes — Docker Desktop normalises them
# e.g. C:/Users/you/monkai/apps/crawler/data/book-data
# macOS/Linux: /Users/you/monkai/apps/crawler/data/book-data
BOOK_DATA_PATH=/path/to/book-data
