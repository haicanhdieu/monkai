# ngrok auth token — from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=<your-ngrok-auth-token>

# Static ngrok domain — from https://dashboard.ngrok.com/domains
# e.g. paying-citizen-nullify.ngrok-free.app
NGROK_DOMAIN=<name>.ngrok-free.app

# Absolute path to the book-data directory on this Windows machine
# Use forward slashes (C:/Users/...) — backslashes are unreliable across Docker Desktop backends
BOOK_DATA_PATH=C:/Users/you/monkai/apps/crawler/data/book-data
